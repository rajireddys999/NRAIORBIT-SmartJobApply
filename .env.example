# ── Database (Supabase free tier) ────────────────────────────
# Get from: supabase.com → project → Settings → Database → Connection string
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SYNC_DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Redis (Upstash free tier) ─────────────────────────────────
# Get from: upstash.com → Create Database → copy Redis URL
REDIS_URL=rediss://default:PASSWORD@xyz.upstash.io:6379

# ── JWT ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── OpenAI (resume embeddings + matching) ────────────────────
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Supabase Storage (resume PDF storage — same project as DB) ───
# SUPABASE_URL: supabase.com → project → Settings → API → Project URL
# SUPABASE_SERVICE_KEY: Settings → API → service_role key (secret!)
# Create a "resumes" bucket in Storage → set to private
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJh...
SUPABASE_STORAGE_BUCKET=resumes

# ── SendGrid (confirmation emails) ───────────────────────────
# Get from: app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Apify (job scraping — Indeed/LinkedIn) ────────────────────
# Get from: console.apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=apify_api_...

# ── Netlify frontend URL (for CORS) ──────────────────────────
# Set this to your Netlify site URL after deploying
FRONTEND_URL=https://your-site.netlify.app

# ── Apify (job scraping — Indeed/LinkedIn) ────────────────────
# Get from: console.apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=apify_api_...

# ── Match threshold ───────────────────────────────────────────
MATCH_SCORE_THRESHOLD=75.0
